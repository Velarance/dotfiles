{
	"layer":"top",
	"position":"top",
	"reload_style_on_change":true,
		
	"height":20,
  "margin-top": 5,
	"margin-left": 5,
	"margin-right":5,
	
	"modules-left":[
    "hyprland/workspaces",
    "custom/crypto",
    "custom/cava",
  ],
"modules-center": [
    "battery",
		"clock#time",
    "backlight",
],
	"modules-right":[
		"custom/notification",
		"network",
		"wireplumber",
    "cpu",
    "memory",
    "hyprland/language",
    "tray",
		"custom/power"
