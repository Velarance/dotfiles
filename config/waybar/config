		    },
		},
        
    "network": {
        "format-wifi": "´ç½   {essid}  ",
        "format-ethernet": "´ÇÆ   {ifname}",
        "format-linked": "´ÇÆ  {ifname} (No IP)",
        "format": "´ÇÆ  Connected",
        "format-disconnected": "´Üö  Disconnected",
        "interval": 60,
        "on-click": "nm-connection-editor"
    },
    "clock#time": {
        "format": "{:%H:%M  %a}",
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // START CLOCK FORMAT
        "format-alt": "{:%d.%m.%Y}"
        // END CLOCK FORMAT
    },
    "custom/power":{
    	"format":"¾░ÉÑ",
