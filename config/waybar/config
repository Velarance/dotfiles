    },

    "cpu": {
        "format": "¾░ıø {usage}%",
        "on-click": "kitty -e btop"
    },

    "memory": {
        "format": "¯┐à {}%",
        "on-click": "kitty -e btop"
    },

    "hyprland/language": {
        "format": "¾░îî {short}"
    },

    "custom/crypto": {
        "format": "{}",
        "interval": 600,
        "return-type": "json",
        "exec": "waybar-crypto",
        "exec-if": "command -v waybar-crypto",
        "on-click": "xdg-open https://coinmarketcap.com/"
    },
    "custom/cava": {
        "exec": "$HOME/dotfiles/config/waybar/cava.sh",
