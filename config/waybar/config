      "interval": 30,
      "format": "{capacity}% ´ëü",
      "format-charging": "{capacity}% ´çĞ",
      "format-plugged": "{capacity}% ´çĞ",
      "format-alt": "{time} {capacity}%",
      "tooltip": true,
      "tooltip-format": "Remaining: {time}"
    },
    "backlight": {
      "device": "amdgpu_bl1",
      "format": "¾░âş {percent}%",
        "on-scroll-up":"brightnessctl set +1%",
